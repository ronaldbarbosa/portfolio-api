{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=portfolio.db"
  },
  "Jwt": {
    "Issuer": "Portfolio.Api",
    "Audience": "Portfolio.Api",
    "ExpiryMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [ "https://ronald-portfolio.vercel.app" ]
  }
}
